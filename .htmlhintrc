{
  "tagname-lowercase": true,
  "attr-lowercase": true,
  "attr-value-double-quotes": true,
  "id-unique": true,
  "doctype-first": true,
  "tag-pair": true,
  "max-empty-lines": 1,
  "indent": 2,
  "max-comments": 1,
  "space-before-tags": false,
  "space-after-tags": false,
  "clean-attr": true
}
